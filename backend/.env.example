# =========================================================================
# Firewall / SNMP
# =========================================================================
FIREWALL_HOST=192.168.2.1
SNMP_VERSION=v3
SNMP_USER=monitor
SNMP_AUTH_KEY=ChangeMeAuthKey123!
SNMP_PRIV_KEY=ChangeMePrivKey123!
SNMP_AUTH_PROTO=SHA
SNMP_PRIV_PROTO=AES
SNMP_PORT=161
SNMP_TIMEOUT_S=3
SNMP_RETRIES=2

# =========================================================================
# Polling
# =========================================================================
POLL_INTERVAL_SECONDS=30

# =========================================================================
# Topology — adjust to match what your USG actually names them
# =========================================================================
WAN_INTERFACES=wan1,wan2,wan3
LAN_INTERFACES=lan1,lan2,lan3,lan4
SFP_INTERFACES=sfp1,sfp2
# WAN_LABELS={"wan1":"Telmex Principal","wan2":"Telmex Secundario","wan3":"Backup"}
WAN_LABELS={}
SESSION_LIMIT_PER_HOST=8000

# =========================================================================
# Syslog (push from firewall)
# Bind port <1024 needs admin on Windows. 5514 is a safe default for dev.
# =========================================================================
SYSLOG_BIND_HOST=0.0.0.0
SYSLOG_BIND_PORT=5514
SYSLOG_MIN_SEVERITY=5
SYSLOG_ALLOWED_SOURCES=*

# =========================================================================
# NetFlow v9 (push from firewall) — needed for top-host-by-bytes charts
# =========================================================================
NETFLOW_ENABLED=false
NETFLOW_BIND_HOST=0.0.0.0
NETFLOW_BIND_PORT=2055
NETFLOW_TOP_N=50

# =========================================================================
# Quality probes (ping from the dashboard server)
# =========================================================================
QUALITY_CHECK_ENABLED=true
QUALITY_CHECK_TARGETS=1.1.1.1,8.8.8.8
QUALITY_CHECK_INTERVAL_S=30
QUALITY_CHECK_COUNT=10

# =========================================================================
# API / UI
# =========================================================================
API_HOST=0.0.0.0
API_PORT=8088

# Dashboard auth (HTTP Basic). Empty DASHBOARD_PASSWORD disables auth.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# =========================================================================
# Persistence
# =========================================================================
DB_PATH=./data/dashboard.db
RETENTION_DAYS=30

# =========================================================================
# Mode
# =========================================================================
MOCK_MODE=true
LOG_LEVEL=INFO

# =========================================================================
# Alerts — webhook (Slack/Teams)
# =========================================================================
ALERT_EVAL_INTERVAL_S=60
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_MIN_SEVERITY=HIGH

# =========================================================================
# Alerts — email (SMTP)
# =========================================================================
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=
ALERT_EMAIL_SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_MIN_SEVERITY=MEDIUM

# =========================================================================
# Firewall health thresholds
# =========================================================================
FW_CPU_THRESHOLD=80
FW_MEM_THRESHOLD=85
